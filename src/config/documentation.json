{
    "openapi": "3.1.0",
    "info": {
        "title": "API de gestion de prêt pour bibliothèques",
        "summary": "API REST pour gérer les livres et les prêts d'une bibliothèque.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080",
            "description": "Serveur de développement"
        },
        {
            "url": "https://sw-final.onrender.com",
            "description": "Serveur en ligne"
        }
    ],
    "components": {
        "securitySchemes": {
            "BearerAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    },
    "paths": {
        "/api/bibliotheques": {
            "post": {
                "summary": "Créer une bibliothèque",
                "tags": ["Bibliothèque"],
                "description": "Crée une nouvelle bibliothèque et retourne sa clé API.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "nom": { "type": "string", "example": "Bibliothèque de Victoriaville" },
                                    "courriel": { "type": "string", "example": "admin@biblio.qc.ca" },
                                    "password": { "type": "string", "example": "motdepasse123" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Bibliothèque créée avec succès" },
                    "400": { "description": "Paramètres manquants" },
                    "409": { "description": "Courriel déjà utilisé" },
                    "500": { "description": "Erreur serveur" }
                }
            }
        },
        "/api/bibliotheques/cle-api": {
            "post": {
                "summary": "Récupérer ou régénérer une clé API",
                "tags": ["Bibliothèque"],
                "description": "Retourne la clé API. Le paramètre optionnel 'regenerer' permet de générer une nouvelle clé.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "courriel": { "type": "string", "example": "admin@biblio.qc.ca" },
                                    "password": { "type": "string", "example": "motdepasse123" },
                                    "regenerer": { "type": "boolean", "example": false }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Clé API retournée ou régénérée avec succès" },
                    "400": { "description": "Paramètres manquants" },
                    "401": { "description": "Mot de passe incorrect" },
                    "404": { "description": "Bibliothèque non trouvée" },
                    "500": { "description": "Erreur serveur" }
                }
            }
        },
        "/api/livres": {
            "get": {
                "summary": "Liste des livres",
                "tags": ["Livres"],
                "description": "Retourne les livres disponibles. Ajouter ?tous=true pour tous les livres.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "in": "query",
                        "name": "tous",
                        "required": false,
                        "schema": { "type": "boolean", "example": false }
                    }
                ],
                "responses": {
                    "200": { "description": "Liste des livres retournée avec succès" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "500": { "description": "Erreur serveur" }
                }
            },
            "post": {
                "summary": "Ajouter un livre",
                "tags": ["Livres"],
                "description": "Ajoute un nouveau livre à la bibliothèque.",
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "titre": { "type": "string", "example": "Le Petit Prince" },
                                    "auteur": { "type": "string", "example": "Antoine de Saint-Exupéry" },
                                    "isbn": { "type": "string", "example": "978-2070612758" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Livre ajouté avec succès" },
                    "400": { "description": "Paramètres manquants" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "500": { "description": "Erreur serveur" }
                }
            }
        },
        "/api/livres/{id}": {
            "get": {
                "summary": "Détail d'un livre",
                "tags": ["Livres"],
                "description": "Retourne le détail d'un livre avec ses prêts.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": { "type": "integer", "example": 1 }
                    }
                ],
                "responses": {
                    "200": { "description": "Détail du livre retourné avec succès" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "404": { "description": "Livre non trouvé" },
                    "500": { "description": "Erreur serveur" }
                }
            },
            "put": {
                "summary": "Modifier un livre",
                "tags": ["Livres"],
                "description": "Modifie les informations d'un livre.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": { "type": "integer", "example": 1 }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "titre": { "type": "string", "example": "Le Petit Prince" },
                                    "auteur": { "type": "string", "example": "Antoine de Saint-Exupéry" },
                                    "isbn": { "type": "string", "example": "978-2070612758" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Livre modifié avec succès" },
                    "400": { "description": "Paramètres manquants" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "404": { "description": "Livre non trouvé" },
                    "500": { "description": "Erreur serveur" }
                }
            },
            "delete": {
                "summary": "Supprimer un livre",
                "tags": ["Livres"],
                "description": "Supprime un livre de la bibliothèque.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": { "type": "integer", "example": 1 }
                    }
                ],
                "responses": {
                    "200": { "description": "Livre supprimé avec succès" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "404": { "description": "Livre non trouvé" },
                    "500": { "description": "Erreur serveur" }
                }
            }
        },
        "/api/livres/{id}/statut": {
            "patch": {
                "summary": "Modifier le statut d'un livre",
                "tags": ["Livres"],
                "description": "Modifie le statut d'un livre (disponible ou emprunté).",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": { "type": "integer", "example": 1 }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "disponible": { "type": "boolean", "example": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Statut modifié avec succès" },
                    "400": { "description": "Paramètre manquant" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "404": { "description": "Livre non trouvé" },
                    "500": { "description": "Erreur serveur" }
                }
            }
        },
        "/api/prets": {
            "post": {
                "summary": "Ajouter un prêt",
                "tags": ["Prêts"],
                "description": "Crée un nouveau prêt et met le livre comme emprunté automatiquement.",
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "livre_id": { "type": "integer", "example": 1 },
                                    "emprunteur": { "type": "string", "example": "Marie Tremblay" },
                                    "date_retour_prevue": { "type": "string", "example": "2026-06-01" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Prêt créé avec succès" },
                    "400": { "description": "Paramètres manquants" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "404": { "description": "Livre non trouvé" },
                    "409": { "description": "Livre déjà emprunté" },
                    "500": { "description": "Erreur serveur" }
                }
            }
        },
        "/api/prets/{id}": {
            "put": {
                "summary": "Modifier un prêt",
                "tags": ["Prêts"],
                "description": "Modifie les informations d'un prêt.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": { "type": "integer", "example": 1 }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "emprunteur": { "type": "string", "example": "Marie Tremblay" },
                                    "date_retour_prevue": { "type": "string", "example": "2026-06-15" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Prêt modifié avec succès" },
                    "400": { "description": "Paramètres manquants" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "404": { "description": "Prêt non trouvé" },
                    "500": { "description": "Erreur serveur" }
                }
            },
            "delete": {
                "summary": "Supprimer un prêt",
                "tags": ["Prêts"],
                "description": "Supprime un prêt.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": { "type": "integer", "example": 1 }
                    }
                ],
                "responses": {
                    "200": { "description": "Prêt supprimé avec succès" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "404": { "description": "Prêt non trouvé" },
                    "500": { "description": "Erreur serveur" }
                }
            }
        },
        "/api/prets/{id}/statut": {
            "patch": {
                "summary": "Modifier le statut d'un prêt",
                "tags": ["Prêts"],
                "description": "Modifie le statut d'un prêt. Si 'RETOURNE', le livre redevient disponible automatiquement.",
                "security": [{ "BearerAuth": [] }],
                "parameters": [
                    {
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": { "type": "integer", "example": 1 }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "statut": { "type": "string", "enum": ["EN_COURS", "RETOURNE"], "example": "RETOURNE" },
                                    "date_retour_reelle": { "type": "string", "example": "2026-05-15" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Statut modifié avec succès" },
                    "400": { "description": "Paramètre manquant ou invalide" },
                    "401": { "description": "Clé API manquante ou invalide" },
                    "404": { "description": "Prêt non trouvé" },
                    "500": { "description": "Erreur serveur" }
                }
            }
        }
    }
}